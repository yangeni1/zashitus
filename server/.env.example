PORT=3000
NODE_ENV=development
TRUST_PROXY=false
SECURE_COOKIES=false

OPENAI_BASE_URL=http://localhost:8080/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=replace-me
PASSWORD_REVIEW_LOCALE=ru
PASSWORD_REVIEW_PROMPT=Оцени пароль как эксперт по безопасности и отвечай только на русском. Учитывай предсказуемость, популярные шаблоны, последовательности, слова, даты, клавиатурные паттерны и похожесть на реальные слабые пароли. Итог должен быть кратким: summary в 1 предложение, максимум 3 рекомендации, каждая не длиннее 2 коротких предложений.

PASSWORD_MAX_LENGTH=256
PASSWORD_AI_DAILY_LIMIT=3
PWNED_PASSWORDS_DAILY_LIMIT=100
PASSWORD_CHECK_BODY_LIMIT_BYTES=4096

PWNED_PASSWORDS_API_URL=https://api.pwnedpasswords.com/range
PWNED_PASSWORDS_RESPONSE_LIMIT_BYTES=1048576
EXTERNAL_REQUEST_TIMEOUT_MS=15000
MODEL_RESPONSE_LIMIT_BYTES=65536

RATE_LIMIT_SECRET=replace-with-long-random-secret
RATE_LIMIT_DB_PATH=data/rate-limits.sqlite
